# Copy this to .env and fill values for local testing
# Stripe API keys (use test keys for development)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Optional SMTP settings for sending emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@youfundhope.org

# Optional contact email
CONTACT_EMAIL=admin@youfundhope.org

# Server port
PORT=3000

# Enable a dev-only test endpoint that creates a PaymentIntent using Stripe's test PM.
# Set to '1' to enable locally only. DO NOT enable in production.
ENABLE_STRIPE_TEST_ENDPOINT=0
